#!/usr/bin/env fish
set PROG 'gopass'

function __fish_gopass_needs_command
  set -l cmd (commandline -opc)
  if [ (count $cmd) -eq 1 ] && [ $cmd[1] = $PROG ]
    return 0
  end
  return 1
end

function __fish_gopass_uses_command
  set cmd (commandline -opc)
  if [ (count $cmd) -gt 1 ]
    if [ $argv[1] = $cmd[2] ]
      return 0
    end
  end
  return 1
end

function __fish_gopass_print_gpg_keys
  gpg2 --list-keys | grep uid | sed 's/.*&lt;\(.*\)>/\1/'
end

function __fish_gopass_print_entries
  gopass ls --flat | sed "s/\\\\/\\\\\\\\/g; s/'/\\\\'/g"
end

function __fish_gopass_print_dir
  for i in (gopass ls --flat | sed "s/\\\\/\\\\\\\\/g; s/'/\\\\'/g")
	  echo (dirname $i)
	end | sort -u
end

# erase any existing completions for gopass
complete -c $PROG -e
complete -c $PROG -f -n '__fish_gopass_needs_command' -a "(__fish_gopass_print_entries)"
complete -c $PROG -f -s c -l clip -r -a "(__fish_gopass_print_entries)"
complete -c $PROG -f -n '__fish_gopass_needs_command' -a age -d 'Command: age commands'
complete -c $PROG -f -n '__fish_gopass_uses_command age' -a agent -d 'Subcommand: Manage the age agent'
complete -c $PROG -f -n '__fish_gopass_uses_command age agent -l help -d "show help"'
complete -c $PROG -f -n '__fish_gopass_uses_command age agent -l yes -d "Always answer yes to yes/no questions"'
complete -c $PROG -f -n '__fish_gopass_uses_command age agent -l clip -d "Copy the password value into the clipboard. Use -c=N to copy line N (0-indexed)"'
